{
  "$schema": "https://axoneditor.com/schemas/theme/v0.1.0.json",
  "name": "Noctis Dark",
  "appearance": "dark",
  "ui": {
    "background": "#0b1020",
    "title_bar.background": "#11172a",
    "toolbar.background": "#11172a",
