    "ansiWhite": "#d8e2f3",
    "ansiBrightBlack": "#6f7f9d",
    "ansiBrightRed": "#ffad9f",
    "ansiBrightGreen": "#b6e89f",
    "ansiBrightYellow": "#f6d78f",
    "ansiBrightBlue": "#a4d8ff",
    "ansiBrightMagenta": "#f4c7e0",
