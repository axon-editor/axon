{
  "$schema": "https://axoneditor.com/schemas/extension/v0.1.0.json",
  "id": "axon.testing",
  "name": "Testing",
  "publisher": "Axon",
  "version": "1.0.0",
  "description": "Built-in test discovery, run orchestration, and result surfaces.",
  "author": "Axon",
  "categories": ["Testing"],
  "activationEvents": [
    "onStartup",
    "onCommand:axon.testing.open",
    "onCommand:axon.testing.refresh",
    "onView:axon.tests"
  ],
  "contributes": {
    "commands": [
      {
        "id": "axon.testing.open",
        "title": "Open Test Explorer",
        "category": "Testing"
      },
      {
        "id": "axon.testing.refresh",
        "title": "Refresh Tests",
        "category": "Testing"
      }
    ],
    "views": [
      {
        "id": "axon.tests",
        "title": "Tests",
        "location": "sidebar"
      }
    ],
    "taskProviders": [
      {
        "type": "test",
        "label": "Axon Tests",
        "description": "Runs tests through Axon's built-in test surface."
      }
    ]
  }
}
