{
  "$schema": "https://axoneditor.com/schemas/extension/v0.1.0.json",
  "id": "axon.terminal",
  "name": "Terminal",
  "publisher": "Axon",
  "version": "1.0.0",
  "description": "Built-in PTY-backed terminal panels and persistent shell sessions.",
  "author": "Axon",
  "kind": "terminal",
  "categories": ["Terminal"],
  "activationEvents": [
    "onStartup",
    "onCommand:axon.terminal.toggle",
    "onCommand:axon.terminal.new",
    "onTerminalProfile:axon.terminal.default"
  ],
  "contributes": {
    "commands": [
      {
        "id": "axon.terminal.toggle",
        "title": "Toggle Terminal",
        "category": "Terminal"
      },
      {
        "id": "axon.terminal.new",
        "title": "New Terminal",
        "category": "Terminal"
      }
    ],
    "views": [
      {
        "id": "axon.terminal",
        "title": "Terminal",
        "location": "panel"
      }
    ],
    "terminalProfiles": [
      {
        "id": "axon.terminal.default",
        "title": "Default Shell"
      }
    ]
  }
}
