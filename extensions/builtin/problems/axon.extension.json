{
  "$schema": "https://axoneditor.com/schemas/extension/v0.1.0.json",
  "id": "axon.problems",
  "name": "Problems",
  "publisher": "Axon",
  "version": "1.0.0",
  "description": "Built-in diagnostics aggregation for Monaco, language servers, and project checks.",
  "author": "Axon",
  "categories": ["Diagnostics"],
  "activationEvents": [
    "onStartup",
    "onCommand:axon.problems.open",
    "onCommand:axon.problems.refresh",
    "onView:axon.problems"
  ],
  "contributes": {
    "commands": [
      {
        "id": "axon.problems.open",
        "title": "Open Problems",
        "category": "Problems"
      },
      {
        "id": "axon.problems.refresh",
        "title": "Refresh Problems",
        "category": "Problems"
      }
    ],
    "views": [
      {
        "id": "axon.problems",
        "title": "Problems",
        "location": "panel"
      }
    ]
  }
}
