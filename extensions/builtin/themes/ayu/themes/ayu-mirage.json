    "editor.findMatchBackground": "#73cffe66",
    "editor.findMatchHighlightBackground": "#73cffe66",
    "editorLineNumber.foreground": "#cccac259",
    "editorLineNumber.activeForeground": "#cccac2ff",
    "editorCursor.foreground": "#72cfffff",
    "editorIndentGuide.background1": "#cccac20d",
    "editorIndentGuide.activeBackground1": "#cccac21a",
    "editorBracketMatch.background": "#72cffe1a",
