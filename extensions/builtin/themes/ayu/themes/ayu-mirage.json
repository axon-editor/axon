    "panel.border": "#43464fff",
    "panel.overlay_hover": "#43464fff",
    "editor.foreground": "#cccac2ff",
    "editor.background": "#242835ff",
    "editor.gutter.background": "#242835ff",
    "terminal.background": "#242835ff",
    "terminal.foreground": "#cccac2ff",
    "syntax.comment": "#b8cfe68c",
    "syntax.keyword": "#ffad65ff",
    "syntax.string": "#d4fe7fff",
    "syntax.number": "#dfbfffff",
    "syntax.type": "#73cfffff",
    "syntax.function": "#ffd173ff",
    "syntax.method": "#ffd173ff",
    "syntax.class": "#72cfffff",
    "syntax.interface": "#73cfffff",
    "syntax.variable": "#cccac2ff",
    "syntax.parameter": "#cccac2ff",
    "syntax.property": "#72cfffff",
    "syntax.constant": "#dfbfffff",
    "syntax.operator": "#f29e74ff",
    "syntax.bracket": "#b4b3aeff",
