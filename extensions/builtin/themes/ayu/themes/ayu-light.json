    "editor.foreground": "#5c6166ff",
    "editor.background": "#fcfcfcff",
    "editor.gutter.background": "#fcfcfcff",
    "terminal.background": "#fcfcfcff",
    "terminal.foreground": "#5c6166ff",
    "syntax.comment": "#787b8099",
    "syntax.keyword": "#fa8d3eff",
