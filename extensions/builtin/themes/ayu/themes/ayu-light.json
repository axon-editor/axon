    "syntax.class": "#3b9ee5ff",
    "syntax.interface": "#389ee6ff",
    "syntax.variable": "#5c6166ff",
    "syntax.parameter": "#5c6166ff",
    "syntax.property": "#3b9ee5ff",
    "syntax.constant": "#a37accff",
