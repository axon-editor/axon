    "toolbar.background": "#fcfcfcff",
    "sidebar.background": "#ececedff",
    "sidebar.hover_background": "#d4d6d8ff",
    "sidebar.border": "#dfe0e1ff",
    "tab.active_background": "#fcfcfcff",
