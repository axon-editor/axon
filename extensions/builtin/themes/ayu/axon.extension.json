{
  "$schema": "https://axoneditor.com/schemas/extension/v0.1.0.json",
  "id": "axon.ayu-theme",
  "name": "Ayu",
  "publisher": "Axon",
  "version": "1.0.0",
  "description": "Built-in Ayu Dark, Ayu Light, and Ayu Mirage themes.",
  "author": "Axon",
  "categories": [
    "Themes"
  ],
  "activationEvents": [
    "onStartup"
  ],
  "contributes": {
    "themes": [
      {
        "id": "ayu-dark",
        "label": "Ayu Dark",
        "path": "./themes/ayu-dark.json"
      },
      {
        "id": "ayu-light",
        "label": "Ayu Light",
        "path": "./themes/ayu-light.json"
      },
      {
        "id": "ayu-mirage",
        "label": "Ayu Mirage",
        "path": "./themes/ayu-mirage.json"
      }
    ]
  }
}
