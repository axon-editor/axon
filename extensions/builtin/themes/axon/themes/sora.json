    "terminal.foreground": "#c8d0e0",
    "syntax.comment": "#586478",
    "syntax.keyword": "#c792ea",
    "syntax.string": "#a6e3a1",
    "syntax.number": "#f9c74f",
    "syntax.type": "#f2b880",
    "syntax.function": "#75d1ff",
