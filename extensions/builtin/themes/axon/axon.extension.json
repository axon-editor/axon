{
  "$schema": "https://axoneditor.com/schemas/extension/v0.1.0.json",
  "id": "axon.themes",
  "name": "Axon Themes",
  "publisher": "Axon",
  "version": "1.0.0",
  "description": "Built-in Axon, Axon Moonlight, and Sora themes.",
  "author": "Axon",
  "categories": [
    "Themes"
  ],
  "activationEvents": [
    "onStartup"
  ],
  "contributes": {
    "themes": [
      {
        "id": "axon-dark",
        "label": "Axon Dark",
        "path": "./themes/axon-dark.json"
      },
      {
        "id": "axon-moonlight",
        "label": "Axon Moonlight",
        "path": "./themes/axon-moonlight.json"
      },
      {
        "id": "sora",
        "label": "Sora",
        "path": "./themes/sora.json"
      }
    ]
  }
}
