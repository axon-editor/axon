{
  "$schema": "https://axoneditor.com/schemas/theme/v0.1.0.json",
  "id": "catppuccin-mocha",
  "name": "Catppuccin Mocha",
  "appearance": "dark",
  "ui": {
    "background": "#1e1e2e",
    "status_bar.background": "#181825",
    "title_bar.background": "#181825",
    "toolbar.background": "#181825",
    "sidebar.background": "#181825",
    "sidebar.hover_background": "#313244",
    "sidebar.border": "#313244",
    "tab.active_background": "#313244",
    "panel.background": "#181825",
    "panel.border": "#313244",
    "panel.overlay_hover": "#313244",
    "editor.foreground": "#cdd6f4",
    "editor.background": "#1e1e2e",
    "editor.gutter.background": "#1e1e2e",
    "terminal.background": "#1e1e2e",
    "terminal.foreground": "#cdd6f4",
    "syntax.comment": "#6c7086",
    "syntax.keyword": "#cba6f7",
    "syntax.string": "#a6e3a1",
    "syntax.number": "#fab387",
    "syntax.type": "#f9e2af",
    "syntax.function": "#89b4fa",
    "syntax.method": "#89b4fa",
    "syntax.class": "#f9e2af",
    "syntax.interface": "#f9e2af",
    "syntax.variable": "#cdd6f4",
    "syntax.parameter": "#f5c2e7",
    "syntax.property": "#94e2d5",
    "syntax.constant": "#f38ba8",
    "syntax.operator": "#89dceb",
    "syntax.bracket": "#bac2de",
    "syntax.import": "#cba6f7",
    "syntax.tag": "#89dceb",
    "syntax.attribute": "#f9e2af"
  },
  "monaco": {
    "editor.lineHighlightBackground": "#313244",
    "editor.selectionBackground": "#45475a",
    "editorLineNumber.foreground": "#6c7086",
    "editorLineNumber.activeForeground": "#89b4fa",
    "editorCursor.foreground": "#f5e0dc",
    "editorIndentGuide.background1": "#45475a",
    "editorIndentGuide.activeBackground1": "#585b70",
    "editorWidget.background": "#181825",
    "editorWidget.border": "#313244",
    "editorSuggestWidget.background": "#181825",
    "editorSuggestWidget.border": "#313244",
    "editorSuggestWidget.selectedBackground": "#313244",
    "editorSuggestWidget.highlightForeground": "#89b4fa",
    "focusBorder": "#89b4fa"
  }
}
