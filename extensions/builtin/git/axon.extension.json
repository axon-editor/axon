{
  "$schema": "https://axoneditor.com/schemas/extension/v0.1.0.json",
  "id": "axon.git",
  "name": "Git",
  "publisher": "Axon",
  "version": "1.0.0",
  "description": "Built-in source-control surfaces for status, diffs, history, branches, stashes, worktrees, and merge conflicts.",
  "author": "Axon",
  "categories": ["Source Control"],
  "activationEvents": [
    "onStartup",
    "onCommand:axon.git.openSourceControl",
    "onCommand:axon.git.openHistory",
    "onCommand:axon.git.refresh",
    "onView:axon.sourceControl",
    "onView:axon.history"
  ],
  "contributes": {
    "commands": [
      {
        "id": "axon.git.openSourceControl",
        "title": "Open Source Control",
        "category": "Git"
      },
      {
        "id": "axon.git.openHistory",
        "title": "Open Git History",
        "category": "Git"
      },
      {
        "id": "axon.git.refresh",
        "title": "Refresh Git Status",
        "category": "Git"
      }
    ],
    "views": [
      {
        "id": "axon.sourceControl",
        "title": "Source Control",
        "location": "sidebar"
      },
      {
        "id": "axon.history",
        "title": "History",
        "location": "sidebar"
      }
    ]
  }
}
