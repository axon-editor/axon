{
  "$schema": "https://axoneditor.com/schemas/extension/v0.1.0.json",
  "id": "axon.language-graphql",
  "name": "GraphQL",
  "publisher": "Axon",
  "version": "1.0.0",
  "description": "Built-in GraphQL language metadata and GraphQL language server ownership.",
  "author": "Axon",
  "categories": ["Languages"],
  "activationEvents": ["onLanguage:graphql"],
  "contributes": {
    "languages": [
      {
        "id": "graphql",
        "label": "GraphQL",
        "extensions": [".graphql", ".gql"],
        "aliases": ["GraphQL", "graphql", "gql"]
      }
    ]
  }
}
