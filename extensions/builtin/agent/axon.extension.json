{
  "$schema": "https://axoneditor.com/schemas/extension/v0.1.0.json",
  "id": "axon.agent",
  "name": "Axon Agent",
  "publisher": "Axon",
  "version": "1.0.0",
  "description": "Built-in local-first AI agent surfaces, project context tools, and terminal companion flows.",
  "author": "Axon",
  "kind": "agent",
  "categories": ["AI"],
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "axon.agent.open",
        "title": "Open Axon Agent",
        "category": "Agent"
      },
      {
        "id": "axon.agent.fixProblems",
        "title": "Fix Problems with Axon Agent",
        "category": "Agent"
      }
    ],
    "views": [
      {
        "id": "axon.agent",
        "title": "Axon Agent Sidebar",
        "location": "sidebar"
      }
    ],
    "agents": [
      {
        "id": "axon.agent.local",
        "title": "Axon Local Agent",
        "description": "Local project assistant backed by Axon's core service.",
        "view": "axon.agent",
        "activationEvent": "onAgent:axon.agent.local"
      }
    ]
  }
}
