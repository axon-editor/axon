    "ansiBrightRed": "#e78284",
    "ansiBrightGreen": "#a6d189",
    "ansiBrightYellow": "#e5c890",
    "ansiBrightBlue": "#8caaee",
    "ansiBrightMagenta": "#f4b8e4",
