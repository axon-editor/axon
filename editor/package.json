{
  "name": "axon",
  "version": "1.1.7",
  "private": true,
  "productName": "Axon",
  "description": "A personal AI-powered code editor built with Electron, React, TypeScript, and Go.",
  "homepage": "https://github.com/GordenArcher/axon",
  "author": {
    "name": "Gorden",
    "email": "GordenArcher@users.noreply.github.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n core,renderer,electron \"cross-env AXON_CORE_PORT=17777 go -C ../core run cmd/axon/main.go\" \"cross-env NODE_ENV=development VITE_AXON_CORE_URL=http://127.0.0.1:17777 vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:17777/health http://127.0.0.1:5173 && cross-env NODE_ENV=development AXON_CORE_PORT=17777 AXON_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:language-servers": "node scripts/download-language-servers.mjs",
    "build:core": "node scripts/build-core.mjs",
    "build:main": "node scripts/write-build-config.mjs && tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:core && npm run build:main && npm run build:renderer",
    "preview": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:mac:x64": "npm run build && electron-builder --mac --x64 --publish never",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64 --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.gorden.axon",
    "productName": "Axon",
    "copyright": "Copyright © 2026 Gorden",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "node_modules/@astrojs/language-server/**/*",
      "node_modules/@mdx-js/language-server/**/*",
      "node_modules/@prisma/language-server/**/*",
      "node_modules/@tailwindcss/language-server/**/*",
      "node_modules/@vue/language-server/**/*",
      "node_modules/bash-language-server/**/*",
      "node_modules/dockerfile-language-server-nodejs/**/*",
      "node_modules/graphql-language-service-server/**/*",
      "node_modules/intelephense/**/*",
      "node_modules/pyright/**/*",
      "node_modules/svelte-language-server/**/*",
      "node_modules/typescript/**/*",
      "node_modules/typescript-language-server/**/*",
      "node_modules/vscode-langservers-extracted/**/*",
      "node_modules/yaml-language-server/**/*"
    ],
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "dist/shared/**/*",
      "extensions/**/*",
      "node_modules/@astrojs/language-server/**/*",
      "node_modules/@mdx-js/language-server/**/*",
      "node_modules/@prisma/language-server/**/*",
      "node_modules/@tailwindcss/language-server/**/*",
      "node_modules/@vue/language-server/**/*",
      "node_modules/bash-language-server/**/*",
      "node_modules/dockerfile-language-server-nodejs/**/*",
      "node_modules/graphql-language-service-server/**/*",
      "node_modules/intelephense/**/*",
      "node_modules/pyright/**/*",
      "node_modules/svelte-language-server/**/*",
      "node_modules/typescript/**/*",
      "node_modules/typescript-language-server/**/*",
      "node_modules/vscode-langservers-extracted/**/*",
      "node_modules/yaml-language-server/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "extraResources": [
      {
        "from": "build/core",
        "to": "core"
      },
      {
        "from": "build/language-servers",
        "to": "language-servers"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "GordenArcher",
        "repo": "axon"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/axon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/axon.png"
    },
    "linux": {
      "category": "Development",
      "maintainer": "Gorden <GordenArcher@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/axon.png"
    }
  },
  "dependencies": {
    "@astrojs/language-server": "^2.16.10",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mdx-js/language-server": "^0.6.3",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/language-server": "^31.11.0",
    "@tailwindcss/language-server": "^0.14.29",
    "@tailwindcss/vite": "^4.3.0",
    "@vscode/codicons": "^0.0.45",
    "@vue/language-server": "^3.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bash-language-server": "^5.6.0",
    "chokidar": "^5.0.0",
    "dockerfile-language-server-nodejs": "^0.15.0",
    "electron-updater": "^6.8.3",
    "graphql-language-service-server": "^2.14.10",
    "intelephense": "^1.18.4",
    "lucide-react": "^1.16.0",
    "pyright": "^1.1.410",
    "react-file-icon": "^1.6.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "svelte-language-server": "^0.18.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vscode-langservers-extracted": "^4.10.0",
    "yaml-language-server": "^1.23.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/chokidar": "^1.7.5",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.10"
  }
}
