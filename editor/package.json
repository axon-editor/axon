{
  "name": "axon",
  "version": "1.0.7",
  "private": true,
  "productName": "Axon",
  "description": "A personal AI-powered code editor built with Electron, React, TypeScript, and Go.",
  "homepage": "https://github.com/GordenArcher/axon",
  "author": {
    "name": "Gorden",
    "email": "GordenArcher@users.noreply.github.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"cross-env NODE_ENV=development vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build:core": "node scripts/build-core.mjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:core && npm run build:main && npm run build:renderer",
    "preview": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:mac:x64": "npm run build && electron-builder --mac --x64 --publish never",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64 --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.gorden.axon",
    "productName": "Axon",
    "copyright": "Copyright © 2026 Gorden",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "dist/shared/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "extraResources": [
      {
        "from": "build/core",
        "to": "core"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "GordenArcher",
        "repo": "axon"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/axon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/axon.png"
    },
    "linux": {
      "category": "Development",
      "maintainer": "Gorden <GordenArcher@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/axon.png"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "react-file-icon": "^1.6.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/chokidar": "^1.7.5",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.10"
  }
}
