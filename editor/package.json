{
  "name": "axon",
  "version": "1.2.5",
  "private": true,
  "productName": "Axon",
  "description": "A personal AI-powered code editor built with Electron, React, TypeScript, and Go.",
  "homepage": "https://github.com/GordenArcher/axon",
  "author": {
    "name": "Gorden",
    "email": "GordenArcher@users.noreply.github.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run sync:builtin && npm run check:language-servers && concurrently -k -n core,renderer,electron \"cross-env AXON_CORE_PORT=17777 go -C ../services/core run cmd/axon/main.go\" \"cross-env NODE_ENV=development VITE_AXON_CORE_URL=http://127.0.0.1:17777 vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:17777/health http://127.0.0.1:5173 && cross-env NODE_ENV=development AXON_CORE_PORT=17777 AXON_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "check:language-servers": "node scripts/check-language-servers.mjs",
    "build:language-servers": "node scripts/download-language-servers.mjs",
    "build:core": "node scripts/build-core.mjs",
    "build:main": "node scripts/write-build-config.mjs && tsc -p tsconfig.main.json",
    "sync:builtin-assets": "node scripts/sync-builtin-assets.mjs",
    "sync:builtin-themes": "node scripts/export-builtin-theme-extensions.mjs",
    "sync:builtin": "npm run sync:builtin-themes && npm run sync:builtin-assets",
    "build:renderer": "npm run sync:builtin && vite build",
    "build": "npm run sync:builtin && npm run patch:language-servers && npm run build:core && npm run build:main && npm run build:renderer",
    "preview": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:mac:x64": "npm run build && electron-builder --mac --x64 --publish never",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64 --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "patch:language-servers": "node scripts/patch-language-servers.mjs"
  },
  "build": {
    "appId": "com.gorden.axon",
    "productName": "Axon",
    "copyright": "Copyright © 2026 Gorden",
    "directories": {
      "output": "release"
    },
