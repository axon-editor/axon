{
  "name": "axon-workspace",
  "version": "1.2.5",
  "private": true,
  "workspaces": [
    "apps/editor",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:extension-api && npm --workspace axon run dev",
    "build": "npm run build:packages && npm --workspace axon run build",
    "build:packages": "node build/build-packages.mjs",
    "build:extension-api": "npm --workspace @axon/extension-api run build",
    "build:protocol": "npm --workspace @axon/protocol run build",
    "build:ipc": "npm --workspace @axon/ipc run build",
    "build:config": "npm --workspace @axon/config run build",
    "build:editor-main": "npm --workspace axon run build:main",
    "build:editor-renderer": "npm --workspace axon run build:renderer",
    "check:line-count": "node tools/check-file-lines.mjs"
  }
}
